SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional — Google Cloud Vision API key for Tamil OCR of official TNPSC PDFs
# (enable "Cloud Vision API" in Google Cloud Console, then create an API key).
GOOGLE_VISION_API_KEY=

# Optional — Anthropic API key for AI explanation generation
# (generate_explanations.py). Get one at console.anthropic.com.
ANTHROPIC_API_KEY=
# Optional model override (default claude-opus-4-8). Set claude-haiku-4-5 for ~5x cheaper.
EXPLANATION_MODEL=
